#!/usr/bin/env bash
# journey:group=capture
# journey:name=capture text-extraction
# journey:summary=Select a region and OCR the text into the clipboard
# journey:examples=journey-capture-text-extraction

set -euo pipefail
for c in grim slurp tesseract wl-copy; do
    command -v "$c" >/dev/null || { command -v notify-send >/dev/null && notify-send -u critical "OCR" "$c not installed"; exit 1; }
done

geom="$(slurp)" || exit 0
tmp="$(mktemp --suffix=.png)"
grim -g "$geom" "$tmp"
tesseract "$tmp" - 2>/dev/null | wl-copy
rm -f "$tmp"

command -v notify-send >/dev/null && notify-send -u low " OCR" "Text copied to clipboard" || true

#!/usr/bin/env bash
# journey:group=ui
# journey:name=pick
# journey:summary=Show a picker over stdin lines, print selected item to stdout
# journey:args=[--prompt P] [--placeholder P] [--height N]
# journey:examples=printf '%s\n' a b c | journey-pick --prompt "Pick one"

# Backend selection (first available wins):
#   1. walker --dmenu     — Journey Companion launcher, used in Wayland sessions
#   2. gum choose         — TTY-friendly, used when no Wayland session
#   3. fzf                — last resort
#
# Exit codes: 0 on selection, 1 on cancel/empty.
set -euo pipefail

prompt=""; placeholder=""; height=400
while (( $# > 0 )); do
    case "$1" in
        --prompt)      prompt="$2"; shift 2 ;;
        --placeholder) placeholder="$2"; shift 2 ;;
        --height)      height="$2"; shift 2 ;;
        -h|--help)     sed -n '2,12p' "$0"; exit 0 ;;
        *)             printf 'journey-pick: unknown flag: %s\n' "$1" >&2; exit 2 ;;
    esac
done

# Walker dmenu mode — only when we're in a Wayland session.
if [[ -n ${WAYLAND_DISPLAY:-} ]] && command -v walker >/dev/null; then
    # Start the walker service if it isn't already running (idempotent).
    if ! pgrep -x walker >/dev/null 2>&1; then
        if command -v uwsm-app >/dev/null; then
            setsid uwsm-app -- env GSK_RENDERER=cairo walker --gapplication-service >/dev/null 2>&1 &
        else
            setsid env GSK_RENDERER=cairo walker --gapplication-service >/dev/null 2>&1 &
        fi
        # Give the service a moment to come up; walker --dmenu otherwise races.
        for _ in 1 2 3 4 5; do
            pgrep -x walker >/dev/null 2>&1 && break
            sleep 0.1
        done
    fi
    args=(--dmenu --width 644 --maxheight "$height" --minheight "$height")
    [[ -n $placeholder ]] && args+=(--placeholder "$placeholder")
    exec walker "${args[@]}"
fi

if command -v gum >/dev/null; then
    args=()
    [[ -n $prompt ]] && args+=(--header "$prompt")
    exec gum choose "${args[@]}"
fi

if command -v fzf >/dev/null; then
    args=()
    [[ -n $prompt ]] && args+=(--prompt "$prompt > ")
    exec fzf "${args[@]}"
fi

echo "journey-pick: no picker available (walker / gum / fzf)" >&2
exit 1

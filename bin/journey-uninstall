#!/usr/bin/env bash
# journey:group=system
# journey:name=uninstall
# journey:summary=Remove Journey Companion from this machine (restores backups when present)
# journey:args=[--yes] [--purge] [--keep-configs]
# journey:examples=journey-uninstall --purge

# What this does — in order:
#   1. Drop the curated Journey configs (`~/.config/<name>` for every entry in
#      $JOURNEY_HOME/default/). If a `<name>.pre-journey.<ts>` backup exists,
#      restore the most recent one in place. Skip with --keep-configs.
#   2. Remove the systemd-user environment.d snippet and the shell-rc include.
#   3. Remove ~/.local/share/journey (the install tree itself).
#   4. With --purge: also delete ~/.config/journey (themes, hooks, reminders).
#
# Does NOT uninstall packages — pacman manages those, and many are useful
# outside Journey. Run `journey-pkg-remove <pkg>` for any you want gone.
set -euo pipefail

JOURNEY_HOME="${JOURNEY_HOME:-$(dirname "$(dirname "$(readlink -f "$0")")")}"
JOURNEY_CONFIG="${JOURNEY_CONFIG:-$HOME/.config/journey}"

yes=0; purge=0; keep_configs=0
for arg in "$@"; do
    case "$arg" in
        --yes|-y)        yes=1 ;;
        --purge)         purge=1 ;;
        --keep-configs)  keep_configs=1 ;;
        -h|--help)       sed -n '2,17p' "$0"; exit 0 ;;
        *) echo "journey-uninstall: unknown flag: $arg" >&2; exit 2 ;;
    esac
done

c_blue=$'\033[1;34m'; c_dim=$'\033[2m'; c_reset=$'\033[0m'
step() { printf '%s==>%s %s\n' "$c_blue" "$c_reset" "$*"; }
note() { printf '%s    %s%s\n' "$c_dim" "$*" "$c_reset"; }

# --- preview ---------------------------------------------------------------
echo "This will:"
(( keep_configs )) || echo "  - Restore or remove ~/.config/<name> for entries in default/ (backups restored when present)"
echo "  - Remove ~/.config/environment.d/10-journey.conf"
echo "  - Remove path.sh inclusion from .bashrc / .zshrc"
echo "  - Remove $JOURNEY_HOME (the install tree)"
(( purge )) && echo "  - Remove $JOURNEY_CONFIG (themes, hooks, reminders, user state)"
echo "  - Will NOT touch: installed pacman/AUR packages"
echo

if ! (( yes )); then
    read -rp "Proceed? [y/N] " ans
    case "${ans,,}" in y|yes) ;; *) echo "Aborted."; exit 0 ;; esac
fi

# --- 1. unstow configs -----------------------------------------------------
unstow_configs() {
    [[ -d $JOURNEY_HOME/default ]] || return 0
    step "Restoring / removing stowed configs"
    local entry name dst backup
    for entry in "$JOURNEY_HOME"/default/*; do
        [[ -e $entry ]] || continue
        name="$(basename "$entry")"
        dst="$HOME/.config/$name"
        [[ -e $dst ]] || continue

        backup="$(ls -dt "$dst.pre-journey."* 2>/dev/null | head -1 || true)"
        rm -rf "$dst"
        if [[ -n $backup ]]; then
            mv "$backup" "$dst"
            note "$dst ← restored from backup"
        else
            note "$dst (removed; no backup to restore)"
        fi
    done
}

(( keep_configs )) || unstow_configs

# --- 2. environment.d + shell rc -------------------------------------------
step "Cleaning environment.d and shell rc"
rm -f "$HOME/.config/environment.d/10-journey.conf"
rmdir "$HOME/.config/environment.d" 2>/dev/null || true

snippet="$JOURNEY_CONFIG/path.sh"
for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    [[ -f $rc ]] || continue
    if grep -qF "$snippet" "$rc"; then
        # Match: blank line, then "# Journey Companion", then [ -f X ] && . X
        tmp="$(mktemp)"
        awk -v snip="$snippet" '
            BEGIN { skip=0 }
            /^# Journey Companion[[:space:]]*$/ { skip=2; next }
            skip > 0 && index($0, snip) > 0 { skip--; next }
            { print }
        ' "$rc" >"$tmp"
        mv "$tmp" "$rc"
        note "scrubbed $rc"
    fi
done

# --- 3. remove install tree ------------------------------------------------
# Tricky: this script lives *inside* $JOURNEY_HOME/bin. Re-exec from /tmp so
# the rm doesn't yank the file out from under us.
if [[ -d $JOURNEY_HOME && "$(readlink -f "$0")" == "$JOURNEY_HOME"/* ]]; then
    relay="$(mktemp)"
    cat >"$relay" <<EOF
#!/usr/bin/env bash
set -euo pipefail
rm -rf $(printf '%q' "$JOURNEY_HOME")
$( (( purge )) && printf 'rm -rf %s\n' "$(printf '%q' "$JOURNEY_CONFIG")" )
rm -f $(printf '%q' "$relay")
echo "Journey removed."
EOF
    chmod +x "$relay"
    step "Removing $JOURNEY_HOME (and exiting)"
    exec "$relay"
fi

# Not inside JOURNEY_HOME — safe to remove directly.
step "Removing $JOURNEY_HOME"
rm -rf "$JOURNEY_HOME"
(( purge )) && { step "Removing $JOURNEY_CONFIG"; rm -rf "$JOURNEY_CONFIG"; }
echo "Journey removed."

#!/usr/bin/env bash
# journey:group=launch
# journey:name=launch tui
# journey:summary=Run a TUI program in a new terminal
# journey:args=<command> [args...]
# journey:examples=journey-launch-tui btop

set -euo pipefail
BIN_DIR="$(dirname "$(readlink -f "$0")")"

[[ $# -ge 1 ]] || { echo "usage: journey-launch-tui <command> [args...]" >&2; exit 2; }

exec "$BIN_DIR/journey-launch-terminal" "$@"

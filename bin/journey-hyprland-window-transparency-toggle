#!/usr/bin/env bash
# journey:group=hyprland
# journey:name=hyprland window-transparency-toggle
# journey:summary=Toggle the global default-opacity rule (fully opaque ↔ themed alpha)
# journey:examples=journey-hyprland-window-transparency-toggle

# Writes/removes a snippet under ~/.local/state/journey/toggles/hypr/.
# hyprland.conf already sources */*.conf from that directory, so a reload picks it up.
set -euo pipefail
STATE="$HOME/.local/state/journey/toggles/hypr"
mkdir -p "$STATE"
file="$STATE/window-opacity-off.conf"

if [[ -e $file ]]; then
    rm -f "$file"
else
    cat >"$file" <<'EOF'
# Generated by journey-hyprland-window-transparency-toggle.
windowrule = opacity 1.0, match:tag default-opacity
EOF
fi
hyprctl reload >/dev/null 2>&1 || true

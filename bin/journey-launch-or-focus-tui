#!/usr/bin/env bash
# journey:group=launch
# journey:name=launch or-focus-tui
# journey:summary=Focus an existing terminal running a TUI by title, else launch it
# journey:args=<tui-command> [terminal-title-regex]
# journey:examples=journey-launch-or-focus-tui cliamp

# Matches by window title (which xdg-terminal-exec sets to the command being
# run for most terminals). The title regex defaults to the command name.
set -euo pipefail
BIN_DIR="$(dirname "$(readlink -f "$0")")"

cmd="${1:?tui command required}"
title_re="${2:-$cmd}"

if command -v hyprctl >/dev/null && command -v jq >/dev/null; then
    addr="$(hyprctl clients -j 2>/dev/null | jq -r --arg re "$title_re" '
        [.[] | select((.title // "") | test($re; "i"))] | sort_by(-(.focusHistoryID // 0)) | .[0].address // empty
    ')"
    if [[ -n $addr ]]; then
        exec hyprctl dispatch focuswindow "address:$addr"
    fi
fi

exec "$BIN_DIR/journey-launch-tui" "$cmd"

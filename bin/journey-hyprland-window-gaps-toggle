#!/usr/bin/env bash
# journey:group=hyprland
# journey:name=hyprland window-gaps-toggle
# journey:summary=Toggle window gaps + borders (off for max screen real estate)
# journey:examples=journey-hyprland-window-gaps-toggle

set -euo pipefail
STATE="$HOME/.local/state/journey/toggles/hypr"
mkdir -p "$STATE"
file="$STATE/window-gaps-off.conf"

if [[ -e $file ]]; then
    rm -f "$file"
else
    cat >"$file" <<'EOF'
# Generated by journey-hyprland-window-gaps-toggle.
general {
    gaps_in = 0
    gaps_out = 0
    border_size = 0
}
EOF
fi
hyprctl reload >/dev/null 2>&1 || true

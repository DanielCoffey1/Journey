#!/usr/bin/env bash
# journey:group=update
# journey:name=migrate
# journey:summary=Apply pending Journey version migrations
# journey:args=[--list] [--dry-run]
# journey:examples=journey-migrate --list

# Migrations live in $JOURNEY_HOME/install/migrations/ as executable scripts
# named like NNN-short-description.sh (zero-padded for natural sort).
#
# State of applied migrations: ~/.local/state/journey/migrations.done
# (one filename per line). Each migration runs at most once.
#
# A migration script may exit non-zero to abort; we will *not* mark it
# applied and the operator can re-run after fixing.
set -euo pipefail

JOURNEY_HOME="${JOURNEY_HOME:-$(dirname "$(dirname "$(readlink -f "$0")")")}"
MIG_DIR="$JOURNEY_HOME/install/migrations"
STATE_DIR="$HOME/.local/state/journey"
DONE="$STATE_DIR/migrations.done"

mkdir -p "$STATE_DIR"
touch "$DONE"

list_only=0; dry_run=0
for arg in "$@"; do
    case "$arg" in
        --list)    list_only=1 ;;
        --dry-run) dry_run=1 ;;
        -h|--help) sed -n '2,7p' "$0"; exit 0 ;;
        *) echo "journey-migrate: unknown flag: $arg" >&2; exit 2 ;;
    esac
done

# No migrations dir → nothing to do. (Fresh installs hit this path.)
if [[ ! -d $MIG_DIR ]]; then
    (( list_only )) && echo "(no migrations defined)"
    exit 0
fi

mapfile -t all < <(find "$MIG_DIR" -maxdepth 1 -type f -name '*.sh' -printf '%f\n' | sort)

pending=()
for f in "${all[@]}"; do
    grep -Fxq "$f" "$DONE" || pending+=("$f")
done

if (( list_only )); then
    printf 'Applied (%d):\n' "$(wc -l <"$DONE")"
    sed 's/^/  /' "$DONE"
    printf 'Pending (%d):\n' "${#pending[@]}"
    for f in "${pending[@]}"; do printf '  %s\n' "$f"; done
    exit 0
fi

(( ${#pending[@]} == 0 )) && { echo "All migrations applied."; exit 0; }

for f in "${pending[@]}"; do
    path="$MIG_DIR/$f"
    echo "==> migrate: $f"
    if (( dry_run )); then continue; fi
    if "$path"; then
        printf '%s\n' "$f" >>"$DONE"
    else
        echo "journey-migrate: $f failed (exit $?) — stopping" >&2
        exit 1
    fi
done

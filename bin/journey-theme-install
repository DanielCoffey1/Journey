#!/usr/bin/env bash
# journey:group=theme
# journey:name=theme install
# journey:summary=Install a theme from a local directory, archive, or git URL
# journey:args=<source> [--name <name>] [--activate]
# journey:examples=journey theme install ./my-theme --activate

set -euo pipefail

JOURNEY_HOME="${JOURNEY_HOME:-$(dirname "$(dirname "$(readlink -f "$0")")")}"
JOURNEY_CONFIG="${JOURNEY_CONFIG:-$HOME/.config/journey}"
USER_THEMES="$JOURNEY_CONFIG/themes"

usage() { sed -n '2,6p' "$0" >&2; exit 1; }

source=""; override_name=""; activate=0
while (( $# > 0 )); do
    case "$1" in
        --name)      override_name="$2"; shift 2 ;;
        --activate)  activate=1; shift ;;
        -h|--help)   sed -n '2,6p' "$0"; exit 0 ;;
        -*)          printf 'unknown flag: %s\n' "$1" >&2; usage ;;
        *)
            [[ -z $source ]] || { printf 'multiple sources given\n' >&2; usage; }
            source="$1"; shift ;;
    esac
done
[[ -z $source ]] && usage

mkdir -p "$USER_THEMES"
workdir="$(mktemp -d)"
trap 'rm -rf "$workdir"' EXIT

# Stage the theme under workdir/extracted/, then look for a directory inside
# that contains colors.toml or walker.css.
mkdir -p "$workdir/extracted"

fetch_source() {
    case "$source" in
        http://*|https://*)
            if [[ $source == *.git ]]; then
                command -v git >/dev/null || { echo "git required for $source" >&2; exit 1; }
                git clone --depth 1 "$source" "$workdir/extracted/clone"
            else
                command -v curl >/dev/null || { echo "curl required" >&2; exit 1; }
                local f="$workdir/download.$(basename "$source")"
                curl -fsSL "$source" -o "$f"
                extract_archive "$f"
            fi
            ;;
        git@*:*|ssh://*)
            command -v git >/dev/null || { echo "git required for $source" >&2; exit 1; }
            git clone --depth 1 "$source" "$workdir/extracted/clone"
            ;;
        *)
            if [[ -d $source ]]; then
                cp -a "$source" "$workdir/extracted/dir"
            elif [[ -f $source ]]; then
                extract_archive "$source"
            else
                echo "no such file or directory: $source" >&2
                exit 1
            fi
            ;;
    esac
}

extract_archive() {
    local archive="$1"
    case "$archive" in
        *.tar.gz|*.tgz) tar -xzf "$archive" -C "$workdir/extracted" ;;
        *.tar.xz)       tar -xJf "$archive" -C "$workdir/extracted" ;;
        *.tar.bz2)      tar -xjf "$archive" -C "$workdir/extracted" ;;
        *.tar)          tar -xf  "$archive" -C "$workdir/extracted" ;;
        *.zip)          command -v unzip >/dev/null || { echo "unzip required" >&2; exit 1; }
                        unzip -q "$archive" -d "$workdir/extracted" ;;
        *)              echo "unsupported archive: $archive" >&2; exit 1 ;;
    esac
}

# Find a valid theme dir inside the extracted tree.
find_theme_root() {
    local hit
    hit="$(find "$workdir/extracted" -maxdepth 4 -type f \( -name colors.toml -o -name walker.css \) -printf '%h\n' 2>/dev/null | sort -u | head -1)"
    [[ -n $hit ]] || { echo "no colors.toml or walker.css found inside source" >&2; exit 1; }
    printf '%s\n' "$hit"
}

fetch_source
theme_root="$(find_theme_root)"

# Pick a name: --name flag, then theme dir name, then archive basename.
if [[ -n $override_name ]]; then
    name="$override_name"
else
    name="$(basename "$theme_root")"
    # If we cloned a git repo, strip .git from the name.
    name="${name%.git}"
fi

dest="$USER_THEMES/$name"
if [[ -e $dest ]]; then
    printf 'journey theme install: %s already exists at %s — remove first\n' "$name" "$dest" >&2
    exit 1
fi

cp -a "$theme_root" "$dest"
printf 'Installed theme "%s" → %s\n' "$name" "$dest"

if (( activate )); then
    "$JOURNEY_HOME/bin/journey-theme-set" "$name"
fi

#!/usr/bin/env bash
# journey:group=toggle
# journey:name=toggle nightlight
# journey:summary=Enable / disable warm-tone nightlight (hyprsunset)
# journey:examples=journey-toggle-nightlight

set -euo pipefail
STATE="$HOME/.local/state/journey/toggles"
mkdir -p "$STATE"
marker="$STATE/nightlight-on"

if [[ -e $marker ]]; then
    rm -f "$marker"
    pkill -x hyprsunset 2>/dev/null || true
    command -v notify-send >/dev/null && notify-send -u low "Nightlight" "Off" || true
else
    : >"$marker"
    if command -v hyprsunset >/dev/null; then
        if command -v uwsm-app >/dev/null; then
            setsid uwsm-app -- hyprsunset -t 3500 >/dev/null 2>&1 &
        else
            setsid hyprsunset -t 3500 >/dev/null 2>&1 &
        fi
        command -v notify-send >/dev/null && notify-send -u low "Nightlight" "On" || true
    fi
fi

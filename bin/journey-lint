#!/usr/bin/env bash
# journey:group=dev
# journey:name=lint
# journey:summary=Run shellcheck across bin/, hooks/, and install.sh
# journey:args=[--install] [--summary]
# journey:examples=journey-lint --summary

# Default behavior: shellcheck every bash script in the project. Lines with
# `# shellcheck disable=...` opt out of specific warnings.
#
# --install   try to install shellcheck via pacman if missing
# --summary   one line of output per file, plus a final pass/fail count
set -euo pipefail

JOURNEY_HOME="${JOURNEY_HOME:-$(dirname "$(dirname "$(readlink -f "$0")")")}"

install=0; summary=0
for arg in "$@"; do
    case "$arg" in
        --install) install=1 ;;
        --summary) summary=1 ;;
        -h|--help) sed -n '2,10p' "$0"; exit 0 ;;
        *) echo "journey-lint: unknown flag: $arg" >&2; exit 2 ;;
    esac
done

if ! command -v shellcheck >/dev/null; then
    if (( install )); then
        sudo pacman -S --needed --noconfirm shellcheck
    else
        echo "journey-lint: shellcheck not installed. Run with --install or:" >&2
        echo "    sudo pacman -S shellcheck" >&2
        exit 1
    fi
fi

mapfile -t files < <(
    find "$JOURNEY_HOME/bin" "$JOURNEY_HOME/hooks" -type f \( -perm -u+x -o -name '*.sh' \) 2>/dev/null
    [[ -f $JOURNEY_HOME/install.sh ]] && echo "$JOURNEY_HOME/install.sh"
    find "$JOURNEY_HOME/default/waybar" -name '*.sh' 2>/dev/null
)

pass=0; fail=0
for f in "${files[@]}"; do
    if shellcheck -x -S warning "$f" >/dev/null 2>&1; then
        (( pass++ ))
        (( summary )) || true
    else
        (( fail++ ))
        if (( summary )); then
            printf '✗ %s\n' "${f#$JOURNEY_HOME/}"
        else
            printf '\n=== %s ===\n' "${f#$JOURNEY_HOME/}"
            shellcheck -x -S warning "$f" || true
        fi
    fi
done

printf '\n%d passed, %d failed (of %d files)\n' "$pass" "$fail" "${#files[@]}"
exit "$(( fail > 0 ? 1 : 0 ))"

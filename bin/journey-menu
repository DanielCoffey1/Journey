#!/usr/bin/env bash
# journey:group=menu
# journey:name=menu
# journey:summary=Open a Journey menu (root menu when no subcommand given)
# journey:args=[<subcommand>] [args...]
# journey:examples=journey-menu system

# Dual-mode:
#   journey-menu                  → shows the root menu picker
#   journey-menu <name> [args...] → exec journey-menu-<name> with the rest

set -euo pipefail
BIN_DIR="$(dirname "$(readlink -f "$0")")"

if (( $# > 0 )); then
    sub="$1"; shift
    target="$BIN_DIR/journey-menu-$sub"
    if [[ -x $target ]]; then
        exec "$target" "$@"
    else
        printf 'journey-menu: no such submenu: %s\n' "$sub" >&2
        printf 'Available: %s\n' "$(find "$BIN_DIR" -maxdepth 1 -name 'journey-menu-*' -perm -u+x -printf '%f\n' | sed 's/^journey-menu-//' | sort | paste -sd, -)" >&2
        exit 1
    fi
fi

# Root menu — enumerate submenus, let the user pick.
declare -A labels=(
    [system]="    System (power)"
    [capture]="   Capture (screenshot / record)"
    [keybindings]="    Keybindings"
    [theme]="    Theme"
    [background]="    Background"
    [toggle]="    Toggle"
    [hardware]="    Hardware"
)
order=(system capture keybindings theme background toggle hardware)

items=""
for key in "${order[@]}"; do
    [[ -x $BIN_DIR/journey-menu-$key ]] || continue
    items+="${labels[$key]}|$key"$'\n'
done

choice="$(printf '%s' "$items" | awk -F'|' '{print $1}' | "$BIN_DIR/journey-pick" --prompt "Journey menu" --placeholder " Menu...")"
[[ -z $choice ]] && exit 0

key="$(printf '%s' "$items" | awk -F'|' -v c="$choice" '$1==c {print $2; exit}')"
[[ -z $key ]] && exit 0

exec "$BIN_DIR/journey-menu-$key"

#!/usr/bin/env bash
# journey:group=hyprland
# journey:name=hyprland window-single-square-aspect-toggle
# journey:summary=Constrain a lone window to a 1:1 square layout (good on ultrawides)
# journey:examples=journey-hyprland-window-single-square-aspect-toggle

set -euo pipefail
STATE="$HOME/.local/state/journey/toggles/hypr"
mkdir -p "$STATE"
file="$STATE/single-square-aspect.conf"

if [[ -e $file ]]; then
    rm -f "$file"
else
    cat >"$file" <<'EOF'
# Generated by journey-hyprland-window-single-square-aspect-toggle.
layout {
    single_window_aspect_ratio = 1 1
}
EOF
fi
hyprctl reload >/dev/null 2>&1 || true
